{
  "name": "@wastedcode/memex",
  "version": "0.1.0",
  "description": "Isolated, queued claude -p runtime for persistent knowledge bases",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "memex": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/cli/client.js",
    "./types": "./dist/lib/types.js",
    "./errors": "./dist/lib/errors.js",
    "./constants": "./dist/lib/constants.js"
  },
  "scripts": {
    "install": "node-gyp rebuild",
    "build": "tsc",
    "bundle": "node esbuild.config.js",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build && npm run bundle"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wastedcode/memex.git"
  },
  "homepage": "https://github.com/wastedcode/memex#readme",
  "bugs": {
    "url": "https://github.com/wastedcode/memex/issues"
  },
  "keywords": [
    "memex",
    "wiki",
    "knowledge-base",
    "claude",
    "ai",
    "daemon",
    "cli"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "files": [
    "dist"
  ],
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.3"
  }
}
